PORT=4000
NODE_ENV=development

FRONTEND_URL=http://localhost:3000

DATABASE_URL=your_database_url_here

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d

UPLOAD_MAX_SIZE_MB=25
UPLOAD_ALLOWED_TYPES=pdf,jpg,jpeg,png

AI_PROVIDER=your_ai_provider_here
AI_API_KEY=your_ai_api_key_here

PAYMENT_PROVIDER=demo
PAYMENT_SECRET_KEY=your_payment_secret_key_here
API_PUBLIC_URL=http://localhost:4000
LEXIA_PAY_PLATFORM_FEE_RATE=0.10

# Mercado Pago Marketplace / Checkout Pro
# En producción usa credenciales live. En pruebas usa credenciales test.
MERCADO_PAGO_ACCESS_TOKEN=your_mercado_pago_access_token_here

# Cripto: opción 1, Coinbase Commerce
COINBASE_COMMERCE_API_KEY=your_coinbase_commerce_api_key_here
COINBASE_COMMERCE_VERSION=2018-03-22

# Cripto: opción 2, proveedor propio compatible con checkoutUrl/paymentUrl
CRYPTO_CHECKOUT_API_URL=your_crypto_checkout_api_url_here
CRYPTO_CHECKOUT_API_KEY=your_crypto_checkout_api_key_here
CRYPTO_CHECKOUT_ASSET=BTC

# Supabase Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Debe estar incluida en Supabase Auth > URL Configuration > Redirect URLs
AUTH_EMAIL_REDIRECT_URL=http://localhost:3000/?verified=true
